on load:
    if {logs::msg_load_done} is not set:
        set {logs::msg_load_done} to true
        set {_m} to mini message from "<gradient:#4facfe:#00f2fe><bold>MSG SYSTEM</bold></gradient> <gray>› <white>Advanced Messaging Loaded!"
        broadcast " "
        send {_m} to all players
        broadcast " "
    set {msg.conf::self} to true if {msg.conf::self} is not set
    set {msg.conf::sound_sent} to "ui.button.click" if {msg.conf::sound_sent} is not set
    set {msg.conf::sound_recv} to "entity.arrow.hit_player" if {msg.conf::sound_recv} is not set

command /privatemessage [<text>] [<text>]:
    trigger:
        set {_p} to mini message from "<gradient:#4facfe:#00f2fe><bold>MSG</bold></gradient> <dark_gray>›<reset> "
        
        if arg-1 or arg-2 is not set:
            send mini message from "%{_p}%<yellow>Usage: /msg <player> <message>"
            stop
            
        set {_t} to arg-1 parsed as player
        if {_t} is not set:
            send mini message from "%{_p}%<red>Player not found!"
            stop
            
        if {msg.conf::self} is true:
            if {_t} is player:
                if player does not have permission "msg.admin":
                    send mini message from "%{_p}%<red>You cannot message yourself!"
                    stop

        if arg-2 is not set:
            send mini message from "%{_p}%<yellow>Usage: /msg %{_t}% <message>"
            stop

        set {_waited} to difference between {msg.lastsend::%uuid of player%} and now
        if player does not have permission "msg.bypass":
            if {_waited} is less than "%{msg.cooldown.time} ? 2% seconds" parsed as timespan:
                send mini message from "%{_p}%<red>Please wait before sending another message."
                stop

        if {msg.toggle::%uuid of {_t}%} is set:
            if player does not have permission "msg.bypass":
                send mini message from "%{_p}%<red>%{_t}% has PMs disabled."
                stop
        if {msg.ignore::%uuid of {_t}%::%uuid of player%} is set:
            send mini message from "%{_p}%<red>You are ignored by %{_t}%."
            stop

        set {_msg} to arg-2
        set {msg.reply::%uuid of {_t}%} to player
        set {msg.reply::%uuid of player%} to {_t}
        set {msg.lastsend::%uuid of player%} to now
        set {msg.last_time::%uuid of player%} to now

        send mini message from "<gray>[<white>To <aqua>%{_t}%<gray>] <white>%{_msg}%" to player
        play sound "%{msg.conf::sound_sent}%" with volume 0.5 to player
        
        set {_recv} to mini message from "<hover:show_text:'<aqua>Click to reply'><click:suggest_command:'/msg %player% '><gray>[<white>From <aqua>%player%<gray>] <white>%{_msg}%</click></hover>"
        send {_recv} to {_t}
        play sound "%{msg.conf::sound_recv}%" with volume 1 to {_t}

        loop all players:
            if {msg.spy::%uuid of loop-player%} is set:
                if loop-player is not player or {_t}:
                    send mini message from "<dark_gray>[Spy] <gray>%player% -> %{_t}%: <italic>%{_msg}%" to loop-player

command /msg [<text>] [<text>]:
    trigger:
        if arg-1 or arg-2 is not set:
            send mini message from "<gradient:#4facfe:#00f2fe><bold>MSG</bold></gradient> <dark_gray>› <yellow>Usage: /msg <player> <message>"
            stop
        execute player command "/privatemessage %arg 1% %arg 2%"

