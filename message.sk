            stop
        execute player command "/privatemessage %arg 1% %arg 2%"

# --- Admin Settings (Command Based) ---
command /msgadmin [<text>] [<text>] [<text>]:
    permission: msg.admin
    trigger:
        set {_p} to mini message from "<gradient:#4facfe:#00f2fe><bold>ADMIN</bold></gradient> <dark_gray>›<reset> "
        
        if arg-1 is "yourself":
            if arg-2 is "on":
                set {msg.conf::self} to true
                send "%{_p}%Yourself security <green>ENABLED."
            else:
                set {msg.conf::self} to false
                send "%{_p}%Yourself security <red>DISABLED."
                
        else if arg-1 is "cooldown":
            set {msg.cooldown.time} to arg-2 parsed as number
            send "%{_p}%Cooldown set to <aqua>%arg-2% <white>seconds."
            
        else if arg-1 is "sound":
            if arg-2 is "sent":
                set {msg.conf::sound_sent} to arg-3
                send "%{_p}%Sent sound changed to <aqua>%arg-3%"
            else if arg-2 is "received":
                set {msg.conf::sound_recv} to arg-3
                send "%{_p}%Received sound changed to <aqua>%arg-3%"
        else:
            send "%{_p}%/msgadmin <yourself/cooldown/sound> <value>"

# --- Tab Completion ---
on tab complete:
    if event-string is "/msgadmin":
        set tab completions for position 1 to "yourself", "cooldown" and "sound"
        if tab arg 1 is "yourself":
            set tab completions for position 2 to "on" and "off"
        if tab arg 1 is "sound":
            set tab completions for position 2 to "sent" and "received"
    if event-string is "/msg" or "/pm" or "/tell":
        set tab completions for position 1 to all players
